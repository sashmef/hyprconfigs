{
  "layer": "top",
  "position": "top",
  "height": 34,
  "margin-top": 3,   
  "margin-left": 3,  
  "margin-right": 3,  
  "margin-bottom": 3,  
  "spacing": 5,

  "modules-left": ["custom/launcher", "hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": ["cpu", "memory", "pulseaudio", "clock"],

  "custom/launcher": {
    "format": " ", 
    "on-click": "fuzzel",
    "tooltip": false
  },
  
  "hyprland/workspaces": {
    "format": "{icon}",
    "disable-scroll": true,
    "all-outputs": true
  },
  
  "hyprland/window": {
    "max-length": 45
  },
  
  "cpu": {
    "format": "CPU: {usage}%",
    "tooltip": false
  },
  
  "memory": {
    "format": "MEM: {}%",
    "tooltip": false
  },

  "pulseaudio": {
    "format": " VOL: {volume}%"
  },
  
  "clock": {
    "format": "{:%H:%M}",
    "tooltip": false
  }
}
